# ─────────────────────────────────────────────────────────────────────────────
# Smart Farm Management System — Backend Environment Variables
# Copy this file to .env and fill in your actual values.
# In Vercel: add these under Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (required for production)
# Get it from: https://cloud.mongodb.com → Clusters → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smart-farm?retryWrites=true&w=majority

# JWT secret — use a long, random string in production
JWT_SECRET=replace_with_a_strong_random_secret

# Runtime environment
NODE_ENV=production

# (Optional) Frontend origin for CORS — set to your Vercel deployment URL
# Example: https://smart-farm-management-system.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app
